<% layout('layouts/boilerplate') %>

<div id="cluster-map" class="mb-4" role="region" aria-label="Campground locations map"></div>

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h1 class="mb-1">All Campgrounds</h1>
        <p class="text-muted mb-0"><%= pagination.totalCampgrounds %> campground<%= pagination.totalCampgrounds === 1 ? '' : 's' %></p>
    </div>
    <% if (currentUser) { %>
        <a href="/campgrounds/new" class="btn btn-success">Add campground</a>
    <% } %>
</div>

<% if (!camps.length) { %>
    <div class="alert alert-info">No campgrounds have been added yet.</div>
<% } %>

<% for (const camp of camps) { %>
    <article class="card campground-list-card my-3">
        <div class="row g-0">
            <div class="col-md-4 campground-list-media">
                <% if (camp.images.length) { %>
                    <img src="<%= camp.images[0].url %>" alt="Landscape view of <%= camp.title %>" loading="lazy">
                <% } else { %>
                    <div class="image-placeholder" role="img" aria-label="No image available">No image available</div>
                <% } %>
            </div>
            <div class="col-md-8">
                <div class="card-body h-100 d-flex flex-column">
                    <h2 class="h4 card-title"><%= camp.title %></h2>
                    <p class="card-text text-muted"><%= camp.location %></p>
                    <p class="card-text">$<%= camp.price.toFixed(2) %> per night</p>
                    <div class="mt-auto d-flex flex-wrap gap-2">
                        <a href="/campgrounds/<%= camp._id %>" class="btn btn-primary">View campground</a>
                        <% if (currentUser && camp.author && String(camp.author) === String(currentUser._id)) { %>
                            <a href="/campgrounds/<%= camp._id %>/edit" class="btn btn-warning">Edit</a>
                            <form action="/campgrounds/<%= camp._id %>?_method=delete" method="post">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button class="btn btn-danger" type="submit">Delete</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </article>
<% } %>

<% if (pagination.totalPages > 1) { %>
    <nav aria-label="Campground pages">
        <ul class="pagination justify-content-center">
            <li class="page-item <%= pagination.currentPage === 1 ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= pagination.currentPage - 1 %>">Previous</a>
            </li>
            <% for (let page = 1; page <= pagination.totalPages; page++) { %>
                <li class="page-item <%= page === pagination.currentPage ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= page %>"><%= page %></a>
                </li>
            <% } %>
            <li class="page-item <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= pagination.currentPage + 1 %>">Next</a>
            </li>
        </ul>
    </nav>
<% } %>

<script>
    const mapToken = <%- JSON.stringify(mapboxToken) %>;
    const campgrounds = <%- mapDataJson %>;
</script>
<script src="/javascripts/ClusterMap.js"></script>
