<% layout('layouts/boilerplate') %>
    <div class="row">
        <h2 class="text-center">Edit Campground</h2>
        <div class="col-8 offset-2 col-lg-6 offset-lg-3">
            <form action="/campgrounds/<%=camp._id%>?_method=put" method="post" novalidate class="validated-form" enctype="multipart/form-data">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control mb-2" type="text" id="title" name="campground[title]"
                        value="<%=camp.title %>" minlength="3" maxlength="100" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="location">Location</label>
                    <input type="text" class="form-control mb-2" id="location" name="campground[location]"
                        value="<%=camp.location %>" minlength="3" maxlength="150" required>
                </div>
                <div class="mb-3">
                    <label for="formFileMultiple" class="form-label">Images</label>
                    <input class="form-control" type="file" name="image" id="formFileMultiple" accept="image/jpeg,image/png,image/webp" multiple>
                    <div class="form-text">Up to 6 total images, 5 MB each.</div>
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Price</label>
                    <div class="input-group">
                        <span class="input-group-text" id="basic-addon1">$</span>
                        <input type="number" class="form-control" id="price" placeholder="0.00" aria-label="Price per night"
                            aria-describedby="price" name="campground[price]" value="<%=camp.price %>" min="0" max="10000" step="0.01" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="campground[description]" id="description" class="form-control mb-2" cols="30"
                        rows="4" minlength="20" maxlength="2000" required><%=camp.description %></textarea>
                </div>
                <div class="mb-3">
                    <!-- Here, showing images' thumbnails for deletion purpose. Selected images' values(img.filename)
                    will be passed in to deleteImages[] array. Each image has a unique filename, given by cloudinary. -->
                    <% camp.images.forEach((img,i)=>{%>
                        <img src="<%=img.thumbnail%>" class="img-thumbnail edit-thumbnail my-2" alt="Image <%= i + 1 %> of <%= camp.title %>">
                        <div class="form-check-inline">
                            <input class="form-check-input" type="checkbox" value="<%=img.filename %>" name="deleteImages[]" id="image-<%=i%>">
                            <label class="form-check-label" for="image-<%=i%>">
                              Delete ?
                            </label>
                          </div>
                    <%}) %>
                </div>

                <div class="mb-3 row">
                    <div class="col-sm-6 mb-2 mb-sm-0">
                        <button class="btn btn-outline-dark w-100" type="submit">Edit</button>
                    </div>
                    <div class="col-sm-6">
                        <a href="/campgrounds/<%=camp._id%>" class="btn btn-outline-dark w-100">Cancel</a>
                    </div>
                    
                </div>
                
            </form>
        </div>
    </div>
