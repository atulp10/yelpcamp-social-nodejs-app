<% layout('layouts/boilerplate') %>
    <div class="row">
        <h2 class="text-center mt-5">Edit Campground</h2>
        <div class="col-6 offset-3">
            <form action="/campgrounds/<%=camp._id%>?_method=put" method="post" novalidate class="validated-form" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control mb-2" type="text" id="title" name="campground[title]"
                        value="<%=camp.title %>" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="location">Location</label>
                    <input type="text" class="form-control mb-2" id="location" name="campground[location]"
                        value="<%=camp.location %>" required>
                </div>
                <div class="mb-3">
                    <label for="formFileMultiple" class="form-label">Images</label>
                    <input class="form-control" type="file" name="image" id="formFileMultiple" multiple>
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Price</label>
                    <div class="input-group">
                        <span class="input-group-text" id="basic-addon1">$</span>
                        <input type="text" class="form-control" id="price" placeholder="0.00" aria-label="Username"
                            aria-describedby="price" name="campground[price]" value="<%=camp.price %>" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="campground[description]" id="description" class="form-control mb-2" cols="30"
                        rows="3" required><%=camp.description %></textarea>
                </div>
                <div class="mb-3">
                    <% camp.images.forEach((img,i)=>{%>
                        <img src="<%=img.thumbnail%>" class="img-thumbnail my-2" alt="">
                        <div class="form-check-inline">
                            <input class="form-check-input" type="checkbox" value="<%=img.filename %>" name="deleteImages[]" id="image-<%=i%>">
                            <label class="form-check-label" for="image-<%=i%>">
                              Delete ?
                            </label>
                          </div>
                    <%}) %>
                </div>

                <div class="mb-3 row">
                    <div class="col-6">
                        <button class="btn btn-outline-dark w-100" type="submit">Edit Campground</button>
                    </div>
                    <div class="col-6">
                        <a href="/campgrounds" class="btn btn-outline-dark w-100">Cancel</a>
                    </div>
                    
                </div>
                
            </form>
        </div>
    </div>