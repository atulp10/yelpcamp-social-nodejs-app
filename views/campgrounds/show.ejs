<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css">

<div class="row g-4">
    <div class="col-lg-6">
        <% if (camp.images.length) { %>
            <div id="campground-carousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner campground-carousel">
                    <% camp.images.forEach((img, index) => { %>
                        <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                            <img src="<%= img.url %>" alt="View <%= index + 1 %> of <%= camp.title %>">
                        </div>
                    <% }) %>
                </div>
                <% if (camp.images.length > 1) { %>
                    <button class="carousel-control-prev" type="button" data-bs-target="#campground-carousel" data-bs-slide="prev" aria-label="Previous image">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#campground-carousel" data-bs-slide="next" aria-label="Next image">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                <% } %>
            </div>
        <% } else { %>
            <div class="image-placeholder campground-carousel" role="img" aria-label="No image available">No image available</div>
        <% } %>

        <article class="card mt-3">
            <div class="card-body">
                <h1 class="h3 card-title"><%= camp.title %></h1>
                <p class="card-text"><%= camp.description %></p>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><%= camp.location %></li>
                <li class="list-group-item">Submitted by <%= camp.author ? camp.author.username : 'Unknown user' %></li>
                <li class="list-group-item">$<%= camp.price.toFixed(2) %> per night</li>
            </ul>
            <div class="card-body d-flex flex-wrap gap-2">
                <% if (currentUser && camp.author && camp.author.equals(currentUser._id)) { %>
                    <a href="/campgrounds/<%= camp._id %>/edit" class="btn btn-warning">Edit</a>
                    <form action="/campgrounds/<%= camp._id %>?_method=delete" method="post">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-danger" type="submit">Delete</button>
                    </form>
                <% } %>
                <a href="/campgrounds" class="btn btn-outline-secondary">Back to campgrounds</a>
            </div>
        </article>
    </div>

    <div class="col-lg-6">
        <div id="map" class="mb-4" role="region" aria-label="Map showing <%= camp.title %>"></div>

        <% if (currentUser) { %>
            <h2 class="h4">Leave a review</h2>
            <form action="/campgrounds/<%= camp._id %>/reviews" class="mb-4 validated-form" novalidate method="post">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <fieldset class="mb-3">
                    <legend class="visually-hidden">Rating</legend>
                    <div class="starability-basic">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="1 star">
                        <% for (let rating = 1; rating <= 5; rating++) { %>
                            <input type="radio" id="rating-<%= rating %>" name="review[rating]" value="<%= rating %>">
                            <label for="rating-<%= rating %>" title="<%= rating %> stars"><%= rating %> stars</label>
                        <% } %>
                    </div>
                </fieldset>
                <div class="mb-3">
                    <label for="body" class="form-label">Review</label>
                    <textarea class="form-control" name="review[body]" id="body" rows="3" minlength="2" maxlength="1000" required></textarea>
                    <div class="invalid-feedback">Please enter a review.</div>
                </div>
                <button type="submit" class="btn btn-success">Submit review</button>
            </form>
        <% } %>

        <h2 class="h4">Reviews</h2>
        <% if (camp.reviews.length) { %>
            <% for (const review of camp.reviews) { %>
                <article class="card mb-3">
                    <div class="card-body">
                        <h3 class="h6 card-subtitle mb-2">By <%= review.author ? review.author.username : 'Unknown user' %></h3>
                        <p class="starability-result" data-rating="<%= review.rating %>" aria-label="Rated <%= review.rating %> out of 5"></p>
                        <p class="card-text"><%= review.body %></p>
                        <% if (currentUser && review.author && review.author.equals(currentUser._id)) { %>
                            <form action="/campgrounds/<%= camp._id %>/reviews/<%= review._id %>?_method=delete" method="post">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button class="btn btn-sm btn-danger" type="submit">Delete review</button>
                            </form>
                        <% } %>
                    </div>
                </article>
            <% } %>
        <% } else { %>
            <p class="text-muted">No reviews yet.</p>
        <% } %>
    </div>
</div>

<script>
    const mapToken = <%- JSON.stringify(mapboxToken) %>;
    const campground = <%- campgroundJson %>;
</script>
<script src="/javascripts/ShowPageMap.js"></script>
