<% layout('layouts/boilerplate') %>
<div class="">
    <div class="row" >
        <div class="card col-4 offset-4">
            <div class="card-body">
                <h2>Login</h2>
            <form action="/users/login" method="post" novalidate class="validated-form">
    
                <div class="mb-3">
                    <label class="form-label" for="username">Username</label>
                    <input type="text" class="form-control mb-2" id="username" name="username" autofocus required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="password">Password</label>
                    <input type="password" class="form-control mb-2" id="password" name="password" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                
                <div class="d-grid gap-2">
                    <button class="btn btn-success btn-block mb-2">Login</button>
                  </div>
            </form>
            </div>
            
        </div>
</div>
</div>

    